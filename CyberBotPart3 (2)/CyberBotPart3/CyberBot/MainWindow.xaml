<Window x:Class="CyberBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ CyberBot – Cybersecurity Awareness Chatbot"
        Height="660" Width="860"
        MinHeight="560" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Window.Resources>
        <!-- ── Colour palette ──────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgDark"    Color="#0D1117"/>
        <SolidColorBrush x:Key="BgPanel"   Color="#161B22"/>
        <SolidColorBrush x:Key="BgCard"    Color="#21262D"/>
        <SolidColorBrush x:Key="Accent"    Color="#58A6FF"/>
        <SolidColorBrush x:Key="AccentGrn" Color="#3FB950"/>
        <SolidColorBrush x:Key="AccentRed" Color="#F85149"/>
        <SolidColorBrush x:Key="AccentYel" Color="#E3B341"/>
        <SolidColorBrush x:Key="TextMain"  Color="#C9D1D9"/>
        <SolidColorBrush x:Key="TextDim"   Color="#8B949E"/>
        <SolidColorBrush x:Key="Border"    Color="#30363D"/>

        <!-- ── Button style ───────────────────────────────────────────────── -->
        <Style x:Key="CyberBtn" TargetType="Button">
            <Setter Property="Background"   Value="#1F6FEB"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="14,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#388BFD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D60D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource CyberBtn}">
            <Setter Property="Background" Value="#DA3633"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F85149"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource CyberBtn}">
            <Setter Property="Background" Value="#238636"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2EA043"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── TextBox style ──────────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"        Value="#0D1117"/>
            <Setter Property="Foreground"        Value="#C9D1D9"/>
            <Setter Property="CaretBrush"        Value="#58A6FF"/>
            <Setter Property="BorderBrush"       Value="#30363D"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="8,6"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Tab styles ─────────────────────────────────────────────────── -->
        <Style TargetType="TabControl">
            <Setter Property="Background"        Value="#0D1117"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Padding"           Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background"    Value="#161B22"/>
            <Setter Property="Foreground"    Value="#8B949E"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Padding"       Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="#161B22"
                                Padding="16,8"
                                Margin="2,0"
                                CornerRadius="6,6,0,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#1C2128"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ScrollBar style ────────────────────────────────────────────── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Width"        Value="6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="🛡️" FontSize="24" VerticalAlignment="Center"/>
                <TextBlock Text="CyberBot" Foreground="#58A6FF" FontSize="20"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBlock Text="Cybersecurity Awareness Assistant"
                           Foreground="#8B949E" FontSize="13"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                <!-- Name display -->
                <TextBlock x:Name="UserNameBlock" Foreground="#3FB950"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Main Tab Control ───────────────────────────────────────────── -->
        <TabControl Grid.Row="1" x:Name="MainTabs" Margin="10,10,10,10">

            <!-- ════════════════════════════════════════════════════════════
                 TAB 1 : CHAT
                 ════════════════════════════════════════════════════════════ -->
            <TabItem Header="💬  Chat">
                <Grid Background="#161B22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Chat display -->
                    <ScrollViewer Grid.Row="0" x:Name="ChatScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="12,12,12,0">
                        <StackPanel x:Name="ChatPanel"/>
                    </ScrollViewer>

                    <!-- Input row -->
                    <Border Grid.Row="1" Background="#0D1117"
                            BorderBrush="#30363D" BorderThickness="0,1,0,0"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ChatInput" Grid.Column="0"
                                     Height="36"
                                     KeyDown="ChatInput_KeyDown"
                                     VerticalContentAlignment="Center"/>
                            <Button Content="Send ➤" Grid.Column="1"
                                    Style="{StaticResource CyberBtn}"
                                    Width="80" Height="36" Margin="8,0,0,0"
                                    Click="SendChat_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════════════════════════════════════════════════════
                 TAB 2 : TASK ASSISTANT
                 ════════════════════════════════════════════════════════════ -->
            <TabItem Header="📋  Tasks">
                <Grid Background="#161B22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <!-- Task list -->
                    <Border Grid.Column="0" Margin="12,12,6,12"
                            Background="#0D1117"
                            BorderBrush="#30363D" BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="My Cybersecurity Tasks"
                                       Foreground="#58A6FF" FontSize="14"
                                       FontWeight="Bold" Margin="12,10"/>
                            <ListBox x:Name="TaskListBox" Grid.Row="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#C9D1D9"
                                     FontSize="13"
                                     Margin="8,0,8,8"
                                     SelectionChanged="TaskListBox_SelectionChanged"/>
                        </Grid>
                    </Border>

                    <!-- Add task panel -->
                    <Border Grid.Column="1" Margin="6,12,12,12"
                            Background="#0D1117"
                            BorderBrush="#30363D" BorderThickness="1"
                            CornerRadius="8" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Add New Task" Foreground="#58A6FF"
                                       FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

                            <TextBlock Text="Title *" Foreground="#8B949E" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="TaskTitle" Height="34"/>

                            <TextBlock Text="Description" Foreground="#8B949E"
                                       FontSize="12" Margin="0,10,0,4"/>
                            <TextBox x:Name="TaskDesc" Height="64"
                                     TextWrapping="Wrap" AcceptsReturn="True"/>

                            <TextBlock Text="Reminder (days from today)"
                                       Foreground="#8B949E" FontSize="12" Margin="0,10,0,4"/>
                            <TextBox x:Name="ReminderDays" Height="34"/>

                            <Button Content="➕  Add Task"
                                    Style="{StaticResource GreenBtn}"
                                    Height="36" Margin="0,14,0,0"
                                    Click="AddTask_Click"/>

                            <Separator Background="#30363D" Margin="0,16"/>

                            <TextBlock Text="Selected Task Actions"
                                       Foreground="#8B949E" FontSize="12" Margin="0,0,0,8"/>
                            <Button Content="✅  Mark as Done"
                                    Style="{StaticResource CyberBtn}"
                                    Height="34" Margin="0,0,0,8"
                                    Click="MarkDone_Click"/>
                            <Button Content="🗑️  Delete Task"
                                    Style="{StaticResource DangerBtn}"
                                    Height="34"
                                    Click="DeleteTask_Click"/>

                            <TextBlock x:Name="TaskStatus"
                                       Foreground="#3FB950"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════════════════════════════════════════════════════
                 TAB 3 : QUIZ
                 ════════════════════════════════════════════════════════════ -->
            <TabItem Header="🎮  Quiz">
                <Grid Background="#161B22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Quiz header / score bar -->
                    <Border Grid.Row="0" Background="#0D1117"
                            BorderBrush="#30363D" BorderThickness="0,0,0,1"
                            Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Cybersecurity Quiz"
                                           Foreground="#58A6FF" FontSize="15"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="QuizProgressText"
                                           Foreground="#8B949E" FontSize="13"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="QuizScoreText" Grid.Column="1"
                                       Foreground="#E3B341" FontSize="13"
                                       FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Question area -->
                    <ScrollViewer Grid.Row="1" Margin="16" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="QuizPanel">
                            <!-- Start screen shown initially -->
                            <Border Background="#21262D" CornerRadius="8" Padding="24"
                                    HorizontalAlignment="Center" Margin="0,40,0,0">
                                <StackPanel>
                                    <TextBlock Text="🎯 Cybersecurity Quiz"
                                               Foreground="#58A6FF" FontSize="22"
                                               FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Test your knowledge with 12 questions covering&#x0a;phishing, passwords, VPNs, malware and more!"
                                               Foreground="#C9D1D9" FontSize="13"
                                               TextAlignment="Center" Margin="0,12,0,0"/>
                                    <Button Content="▶  Start Quiz"
                                            Style="{StaticResource GreenBtn}"
                                            Width="160" Height="40"
                                            Margin="0,20,0,0"
                                            HorizontalAlignment="Center"
                                            Click="StartQuiz_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Answer buttons row -->
                    <Border Grid.Row="2" x:Name="AnswerArea"
                            Background="#0D1117"
                            BorderBrush="#30363D" BorderThickness="0,1,0,0"
                            Padding="16,10" Visibility="Collapsed">
                        <WrapPanel x:Name="AnswerPanel" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════════════════════════════════════════════════════
                 TAB 4 : ACTIVITY LOG
                 ════════════════════════════════════════════════════════════ -->
            <TabItem Header="📜  Activity Log">
                <Grid Background="#161B22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0D1117"
                            BorderBrush="#30363D" BorderThickness="0,0,0,1"
                            Padding="16,10">
                        <TextBlock Text="📜 Activity Log – Recent Chatbot Actions"
                                   Foreground="#58A6FF" FontSize="14" FontWeight="Bold"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" Margin="12" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="LogPanel"/>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#0D1117"
                            BorderBrush="#30363D" BorderThickness="0,1,0,0"
                            Padding="12,8">
                        <Button Content="🔄  Refresh Log"
                                Style="{StaticResource CyberBtn}"
                                Width="140" Height="34"
                                Click="RefreshLog_Click"/>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
